                            "ctx_des": "Default ctx for ara::com"
                        },
                        {
                            "ctx_id": "adiag",
                            "log_level": "kInfo",
                            "ctx_des": "Default ctx for ara::diag"
                        },
                        {
                            "ctx_id": "exec",
                            "log_level": "kInfo",
                            "ctx_des": "Default ctx for ara::exec"
                        }
                    ]
                }
            },
            "provide": [],
            "require": [
                {
                    "name": "ExampleService as service3",
